<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="72dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="4dp">

    <FrameLayout
        android:layout_width="60dp"
        android:layout_height="60dp">

        <!-- Gradient ring simulé avec un background -->
        <View
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/bg_story_ring"/>

        <!-- Avatar -->
        <ImageView
            android:id="@+id/ivStoryAvatar"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_default_avatar"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_avatar_border"/>

        <!-- Add button pour current user -->
        <ImageView
            android:id="@+id/ivAddStory"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_gravity="bottom|end"
            android:src="@drawable/ic_add_circle"
            android:tint="@color/purple_primary"
            android:background="@color/background_dark"
            android:visibility="gone"/>

    </FrameLayout>

    <TextView
        android:id="@+id/tvStoryUsername"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="username"
        android:textColor="@color/text_secondary"
        android:textSize="10sp"
        android:gravity="center"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginTop="4dp"/>

</LinearLayout>