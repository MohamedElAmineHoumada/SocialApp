<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="72dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="4dp">

    <!-- Story ring + avatar -->
    <FrameLayout
        android:layout_width="60dp"
        android:layout_height="60dp">

        <!-- Gradient ring (custom view) -->
        <com.Groupe15.SocialApp.ui.custom.StoryRingView
            android:id="@+id/storyRing"
            android:layout_width="60dp"
            android:layout_height="60dp"/>

        <!-- Avatar -->
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/ivStoryAvatar"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_default_avatar"/>

        <!-- Add button (only for current user) -->
        <ImageView
            android:id="@+id/ivAddStory"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_gravity="bottom|end"
            android:src="@drawable/ic_add_circle"
            android:tint="@color/purple_primary"
            android:background="@color/background_dark"
            android:visibility="gone"/>

    </FrameLayout>

    <TextView
        android:id="@+id/tvStoryUsername"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="username"
        android:textColor="@color/text_secondary"
        android:textSize="10sp"
        android:fontFamily="@font/nunito_regular"
        android:gravity="center"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginTop="4dp"/>

</LinearLayout>