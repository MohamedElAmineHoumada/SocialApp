<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="68dp"
    android:paddingHorizontal="16dp"
    android:background="?attr/selectableItemBackground">

    <!-- Avatar + online indicator -->
    <FrameLayout
        android:id="@+id/flAvatar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/ivAvatar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_default_avatar"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_avatar_border"/>

        <!-- Online indicator -->
        <View
            android:id="@+id/viewOnlineIndicator"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_gravity="bottom|end"
            android:background="@drawable/bg_online_indicator"
            android:visibility="gone"/>

    </FrameLayout>

    <!-- Username -->
    <TextView
        android:id="@+id/tvConversationUsername"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Username"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:fontFamily="@font/nunito_bold"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintStart_toEndOf="@id/flAvatar"
        app:layout_constraintEnd_toStartOf="@id/tvTimestamp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvLastMessage"/>

    <!-- Timestamp -->
    <TextView
        android:id="@+id/tvTimestamp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="2m ago"
        android:textColor="@color/purple_primary"
        android:textSize="11sp"
        android:fontFamily="@font/nunito_bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/viewUnreadDot"/>

    <!-- Last message -->
    <TextView
        android:id="@+id/tvLastMessage"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Last message..."
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:fontFamily="@font/nunito_bold"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintStart_toEndOf="@id/flAvatar"
        app:layout_constraintEnd_toStartOf="@id/viewUnreadDot"
        app:layout_constraintTop_toBottomOf="@id/tvConversationUsername"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <!-- Unread dot -->
    <View
        android:id="@+id/viewUnreadDot"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:background="@drawable/bg_unread_dot"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTimestamp"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>